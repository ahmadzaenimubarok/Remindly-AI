# App
APP_ENV=development
APP_SECRET_KEY=change-me-in-production-min-32-chars

# Database
DATABASE_URL=postgresql+asyncpg://postgres:yourpassword@localhost:5432/reseller_ai

# Redis
REDIS_URL=redis://localhost:6379/0

# AI Provider
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
AI_MODEL_FAST=meta-llama/llama-3.1-8b-instruct:free
AI_MODEL_QUALITY=meta-llama/llama-3.1-8b-instruct:free

# Meta (Facebook / Messenger)
META_APP_ID=
META_APP_SECRET=
META_VERIFY_TOKEN=
META_REDIRECT_URI=http://localhost:8000/api/v1/auth/facebook/callback
META_IG_REDIRECT_URI=http://localhost:8000/api/v1/auth/instagram/callback
FRONTEND_URL=http://localhost:3000

# TikTok
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=

# WhatsApp Business
WHATSAPP_TOKEN=
WHATSAPP_PHONE_NUMBER_ID=

# Midtrans
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=

# Stripe (opsional)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=

# Email
RESEND_API_KEY=

# Encryption key untuk credential tenant (generate: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())")
CREDENTIAL_ENCRYPTION_KEY=

# Frontend
VITE_API_BASE_URL=http://localhost:8000

# JWT
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=30
